{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "()": "uvicorn.logging.DefaultFormatter",
      "fmt": "%(asctime)s: %(levelprefix)s %(message)s",
      "use_colors": null
    },
    "access": {
      "()": "uvicorn.logging.AccessFormatter",
      "fmt": "%(asctime)s: %(levelprefix)s %(client_addr)s - \"%(request_line)s\" %(status_code)s"
    },
     "json_formatter": {
      "()": "src.svo_log_api.logger.JSONFormatter",
      "fmt_keys": {
        "level": "levelname",
        "message": "message",
        "timestamp": "timestamp",
        "logger": "name",
        "module": "module",
        "function": "funcName",
        "line": "lineno",
        "thread_name": "threadName"
      }
    }
  },
  "handlers": {
    "_default": {
      "formatter": "default",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stderr"
    },
    "_access": {
      "formatter": "access",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    },
    "_default_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "INFO",
      "formatter": "json_formatter",
      "filename": "default.jsonl",
      "maxBytes": 10e6,
      "backupCount": 3
    },
    "_access_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "INFO",
      "formatter": "json_formatter",
      "filename": "access.jsonl",
      "maxBytes": 10e6,
      "backupCount": 3
    },
    "queued_default": {
      "()": "src.svo_log_api.logger.CustomQueueHandler",
      "handler_0": "cfg://handlers._default",
      "handler_1": "cfg://handlers._default_file",
      "respect_handler_level": true
    },
    "queued_access": {
      "()": "src.svo_log_api.logger.CustomQueueHandler",
      "handler_0": "cfg://handlers._access",
      "handler_1": "cfg://handlers._access_file",
      "respect_handler_level": true
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": [
        "queued_default"
      ],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "level": "INFO"
    },
    "uvicorn.access": {
      "handlers": [
        "queued_access"
      ],
      "level": "INFO",
      "propagate": false
    }
  }
}